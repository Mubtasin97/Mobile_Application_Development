<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="8dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="8dp">
        <View android:layout_width="20dp" android:layout_height="20dp" android:background="#4CAF50"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" Available  " android:textSize="12sp"/>
        <View android:layout_width="20dp" android:layout_height="20dp" android:background="#F44336"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" Booked  " android:textSize="12sp"/>
        <View android:layout_width="20dp" android:layout_height="20dp" android:background="#2196F3"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" Selected" android:textSize="12sp"/>
    </LinearLayout>

    <GridView android:id="@+id/gridSeats"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1"
        android:numColumns="6"
        android:verticalSpacing="6dp"
        android:horizontalSpacing="6dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:padding="8dp" android:background="#EEEEEE">
        <TextView android:id="@+id/tvSummary"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="0 seats | Total: ৳0"/>
        <Button android:id="@+id/btnConfirm"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Confirm Booking" android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"/>
    </LinearLayout>
</LinearLayout>